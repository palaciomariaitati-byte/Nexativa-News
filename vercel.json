{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/auto-fetch",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-media",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/news-rotation",
      "schedule": "0 0 * * *"
    }
  ]
}
